{
  "name": "forum-lite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/compat-client-assets.mjs",
    "preview": "vite preview",
    "deploy": "npm run build && node scripts/prepare-deploy-config.mjs && wrangler deploy --config dist/forum_lite/wrangler.json",
    "gsc:submit": "node scripts/search-console-submit.mjs",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply forum-db --local --config wrangler.local.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply forum-db --remote --config wrangler.local.jsonc",
    "seed:local": "wrangler d1 execute forum-db --local --config wrangler.local.jsonc --file=scripts/seed.sql",
    "test:security": "tsx scripts/validate-auth-randomness.ts",
    "import:old-users:sql": "node scripts/import-old-users.mjs",
    "import:old-content:sql": "node scripts/import-old-content.mjs",
    "import:old-tags:sql": "node scripts/import-old-tags.mjs",
    "og:webp": "tsx scripts/render-og-webp.ts",
    "og:webp:threads": "tsx scripts/render-og-webp.ts --threads",
    "og:webp:upload": "tsx scripts/render-og-webp.ts --threads --upload"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.2",
    "@types/marked": "^5.0.2",
    "dompurify": "^3.4.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "marked": "^18.0.5",
    "react-helmet-async": "^3.0.0",
    "zod": "^3.24.1"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.2",
    "@cloudflare/workers-types": "4.20260624.1",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/react-query": "^5.62.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "sharp": "^0.35.2",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "wrangler": "4.104.0"
  }
}
